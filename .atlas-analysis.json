  "keyFeatures": [
    "Real-time audio synthesis and processing",
    "Extensive library of 1500+ opcodes",
    "Multi-platform support (desktop, mobile, web)",
    "Language bindings for C, C++, Python, JavaScript, Java",
    "Plugin system for custom opcodes",
    "WebAssembly support for browser integration",
    "MIDI and OSC support",
    "Advanced spectral processing",
    "Physical modeling synthesis",
    "Ambisonics and spatial audio"
  ],
  "publicApiSurface": [
    "csoundCreate() - Create Csound instance",
    "csoundCompile() - Compile CSD file",
    "csoundCompileOrc() - Compile orchestra code",
    "csoundPerformKsmps() - Process audio blocks",
    "csoundStart() - Start performance",
    "csoundReset() - Reset instance",
    "csoundGetSr() - Get sample rate",
    "csoundGetKsmps() - Get control period",
    "csoundGetSpin() / csoundGetSpout() - Audio buffers",
    "csoundSetOption() - Set runtime options",
    "csoundGetInputChannel() / csoundSetOutputChannel() - Software bus",
    "csoundTableGet() / csoundTableSet() - Function table access",
    "csoundScoreEvent() - Send score events",
    "csoundRunUtility() - Execute utilities",
    "Plugin framework - Custom opcode development",
    "CsoundPerformanceThread - Threading support",
    "JavaScript/WASM API - Browser integration",
    "Python ctcsound - Python bindings"
  ]
